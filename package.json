{
  "name": "whatsapp-analyzer-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "chat-core-wasm/**/*.rs": [
      "cargo fmt --manifest-path chat-core-wasm/Cargo.toml --"
    ]
  },
  "dependencies": {
    "d3-cloud": "^1.2.5",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.10.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "lodash@<4.18.1": "^4.18.1",
      "postcss@<8.5.10": "^8.5.10",
      "flatted@<3.4.2": "^3.4.2",
      "minimatch@<3.1.3": "^3.1.3",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "rollup@<4.59.0": "^4.59.0",
      "picomatch@<2.3.2": "^2.3.2",
      "@tootallnate/once@<2.0.1": "2.0.1"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-cloud": "^1.2.6",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "knip": "^6.16.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.49.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.8"
  }
}
